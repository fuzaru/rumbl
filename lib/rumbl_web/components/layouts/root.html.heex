<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title default="Rumbl" suffix=" · Rumbl">
      {assigns[:page_title]}
    </.live_title>
    <link rel="icon" type="image/png" href={~p"/images/logo.png"} />
    <link rel="apple-touch-icon" href={~p"/images/logo.png"} />
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
    <script>
      (() => {
        const key = "phx:theme";
        const root = document.documentElement;
        const setTheme = (theme) =>
          theme === "system"
            ? (localStorage.removeItem(key), root.removeAttribute("data-theme"))
            : (localStorage.setItem(key, theme), root.setAttribute("data-theme", theme));

        if (!root.hasAttribute("data-theme")) setTheme(localStorage.getItem(key) || "system");

        window.addEventListener("storage", (e) => e.key === key && setTheme(e.newValue || "system"));
        window.addEventListener("phx:set-theme", (e) => setTheme(e.target.dataset.phxTheme));
      })();
    </script>
  </head>
  <body>
    {@inner_content}
  </body>
</html>
